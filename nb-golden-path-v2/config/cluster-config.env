# ──────────────────────────────────────────────
# NB Golden Path — Cluster Configuration
# ──────────────────────────────────────────────
# This is the ONLY file you need to edit when
# deploying to a new OpenShift cluster.
# After editing, run: make render
# ──────────────────────────────────────────────

# OpenShift cluster apps domain
CLUSTER_DOMAIN=apps.cluster-cnhmj.dynamic.redhatworkshops.io

# Coder
CODER_HOST=coder-coder.${CLUSTER_DOMAIN}

# ArgoCD
ARGOCD_HOST=argocd.${CLUSTER_DOMAIN}

# ACS / StackRox
ACS_HOST=acs.${CLUSTER_DOMAIN}

# RHDH
RHDH_HOST=backstage-developer-hub-tssc-dh.${CLUSTER_DOMAIN}

# Grafana
GRAFANA_HOST=grafana.${CLUSTER_DOMAIN}

# Image Registry
IMAGE_REGISTRY=registry.${CLUSTER_DOMAIN}

# GitHub Org (for repo creation)
GITHUB_ORG=sansow

# Storage Class for PVCs
STORAGE_CLASS=gp3-csi

# Coder Workspace Namespace
CODER_NAMESPACE=coder
