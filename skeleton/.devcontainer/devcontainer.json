{
  "name": "${{ values.component_id }} — NB Workspace",
  "image": "registry.nb.internal/devtools/java-workspace:${{ values.java_version }}",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers-contrib/features/maven-sdkman:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.vscode-yaml",
        "redhat.java",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "Continue.continue",
        "redhat.vscode-xml",
        "vscjava.vscode-spring-boot-dashboard"
      ],
      "settings": {
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-${{ values.java_version }}",
            "path": "/usr/lib/jvm/java-${{ values.java_version }}",
            "default": true
          }
        ]
      }
    }
  },
  "forwardPorts": [8080],
  "postCreateCommand": "mvn dependency:resolve -B || true",
  "remoteUser": "coder"
}
